MYSQL_DATABASE=groupshop
MYSQL_USER=groupshop
MYSQL_PASSWORD=change-me-groupshop
MYSQL_ROOT_PASSWORD=change-me-root
JAVA_OPTS=-Xms256m -Xmx512m

# AI polish provider for group-buy publish copy.
# Keep local for offline deterministic fallback, or set openai with an API key.
GROUPSHOP_AI_POLISH_PROVIDER=local #option openai local (chatcompletion only)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20
