{
  "name": "groupshop-h5",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:android": "vite build --mode android",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "typecheck:e2e": "vue-tsc --noEmit -p tsconfig.e2e.json",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,vue,css,scss,json}\"",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config playwright.live.config.ts",
    "cap:sync:android": "npm run build:android && npx cap sync android",
    "apk:debug": "npm run cap:sync:android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@vant/area-data": "^2.1.0",
    "axios": "^1.7.9",
    "pinia": "^3.0.2",
    "qrcode": "^1.5.4",
    "vant": "^4.9.18",
    "vue": "^3.5.38",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^3.1.1",
    "vue-tsc": "^3.3.5"
  }
}
